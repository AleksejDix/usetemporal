{
  "name": "minuta",
  "version": "1.0.0-beta.1",
  "type": "module",
  "description": "Divide time into pieces. Pure functional calendar library with a 4-method adapter contract.",
  "license": "Apache-2.0",
  "author": "Aleksej Dix <git@aleksejdix.com>",
  "homepage": "https://github.com/AleksejDix/minuta",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AleksejDix/minuta.git",
    "directory": "packages/minuta"
  },
  "bugs": {
    "url": "https://github.com/AleksejDix/minuta/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./operations": {
      "types": "./dist/operations.d.ts",
      "import": "./dist/operations.js"
    },
    "./calendar": {
      "types": "./dist/calendar.d.ts",
      "import": "./dist/calendar.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    },
    "./temporal": {
      "types": "./dist/temporal.d.ts",
      "import": "./dist/temporal.js"
    },
    "./luxon": {
      "types": "./dist/luxon.d.ts",
      "import": "./dist/luxon.js"
    },
    "./dayjs": {
      "types": "./dist/dayjs.d.ts",
      "import": "./dist/dayjs.js"
    },
    "./date-fns": {
      "types": "./dist/date-fns.d.ts",
      "import": "./dist/date-fns.js"
    },
    "./date-fns-tz": {
      "types": "./dist/date-fns-tz.d.ts",
      "import": "./dist/date-fns-tz.js"
    },
    "./moment": {
      "types": "./dist/moment.d.ts",
      "import": "./dist/moment.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "1 kB",
      "gzip": true
    },
    {
      "path": "dist/operations.js",
      "limit": "2 kB",
      "gzip": true
    },
    {
      "path": "dist/calendar.js",
      "limit": "1 kB",
      "gzip": true
    },
    {
      "path": "dist/helpers.js",
      "limit": "1 kB",
      "gzip": true
    },
    {
      "path": "dist/native.js",
      "limit": "2 kB",
      "gzip": true
    },
    {
      "path": "dist/dayjs.js",
      "limit": "2 kB",
      "gzip": true
    },
    {
      "path": "dist/date-fns.js",
      "limit": "2 kB",
      "gzip": true
    },
    {
      "path": "dist/date-fns-tz.js",
      "limit": "2 kB",
      "gzip": true
    },
    {
      "path": "dist/luxon.js",
      "limit": "2 kB",
      "gzip": true
    },
    {
      "path": "dist/moment.js",
      "limit": "2 kB",
      "gzip": true
    },
    {
      "path": "dist/temporal.js",
      "limit": "2 kB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@minuta/tsconfig": "2.0.0-alpha.1",
    "@size-limit/file": "^12.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.12.1",
    "@vitest/coverage-v8": "^4.0.13",
    "dayjs": "^1.11.20",
    "jsdom": "^26.0.0",
    "moment": "^2.30.1",
    "size-limit": "^12.0.1",
    "typescript": "^5.7.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^4.0.13"
  },
  "optionalDependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.0.0",
    "luxon": "^3.5.0"
  },
  "keywords": [
    "time",
    "date",
    "temporal",
    "divide",
    "typescript",
    "calendar",
    "stableMonth",
    "pure-functions",
    "framework-agnostic"
  ]
}
